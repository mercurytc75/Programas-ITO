{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compilar Monopoly",
            "type": "shell",
            "command": "javac",
            "args": [
                "-d",
                "bin",
                "-sourcepath",
                "src/main/java",
                "${fileDirname}/${fileBasename}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always"
            }
        },
        {
            "label": "Ejecutar Monopoly",
            "type": "shell",
            "command": "java",
            "args": [
                "-cp",
                "bin",
                "com.monopoly.Main"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always"
            },
            "dependsOn": ["Compilar Monopoly"]
        }
    ]
}
